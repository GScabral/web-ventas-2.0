# ============================================================
# Variables de entorno del BACKEND
# ------------------------------------------------------------
# Copiá este archivo como ".env" (en la misma carpeta /server)
# y completá los valores reales. El .env NUNCA se sube al repo
# (está en .gitignore). En Render, se cargan en Settings ->
# Environment, no en un archivo.
# ============================================================

# ---- Base de datos PostgreSQL ----
# Opción A (recomendada en Render/Neon/Supabase): una sola URL.
DATABASE_URL=postgres://usuario:password@host:5432/nombre_db
# Opción B: campos sueltos (si no usás DATABASE_URL).
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432

# ---- Entorno ----
# "development" muestra logs y detalles de error; en producción dejalo en "production".
NODE_ENV=production

# ---- Seguridad / sesión ----
# Clave para firmar los tokens JWT (admin y clientes). Poné una cadena
# larga y aleatoria, distinta por cada instalación.
SECRET_KEY=

# ---- Acceso del administrador ----
# Definí UNA de las dos: ADMIN_PASSWORD_HASH (hash bcrypt, más seguro)
# o ADMIN_PASSWORD (texto plano, el server lo hashea al iniciar).
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD=
# Opcionales: si los definís, el login exige que coincidan.
ADMIN_EMAIL=
ADMIN_USERNAME=

# ---- Frontend permitido (CORS) ----
# URL del sitio público (el front). Se pueden poner varias separadas por comas.
CLIENT_URL=https://tu-tienda.onrender.com

# ---- Cloudinary (imágenes de productos) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Mercado Pago (cobros online) ----
# Access token y public key de la cuenta de Mercado Pago del comercio.
ACCESS_TOKEN=
MP_PUBLIC_KEY=
# URL pública del backend donde Mercado Pago manda el aviso de pago (webhook).
MP_WEBHOOK_URL=https://tu-backend.onrender.com/mp/webhook
# Secreto para validar la firma del webhook (se saca del panel de Mercado Pago).
MP_WEBHOOK_SECRET=

# ---- Correo (avisos de pedido/envío) ----
# Cuenta de Gmail (u otro SMTP) y su contraseña de aplicación.
EMAIL_USER=
EMAIL_PASS=
