# ============================================================
# Variables de entorno del FRONTEND (Vite)
# ------------------------------------------------------------
# Copiá este archivo como ".env" en la carpeta /vite-project.
# Las variables de Vite DEBEN empezar con VITE_ para que el
# build las tome. El .env no se sube al repo.
# ============================================================

# URL del backend desplegado (sin barra final).
# En desarrollo local, podés apuntar a http://localhost:3004
VITE_API_URL=https://tu-backend.onrender.com
